# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: "ollama", "groq", "gemini"
LLM_PROVIDER=ollama

# ── Ollama Settings ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Groq Settings (optional — only if LLM_PROVIDER=groq) ───────────────────
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Gemini Settings (optional — only if LLM_PROVIDER=gemini) ────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ── Generation Settings ─────────────────────────────────────────────────────
TEMPERATURE=0.7
MAX_TOKENS=4096
REQUEST_TIMEOUT=120
MAX_RETRIES=2

# ── Output Settings ─────────────────────────────────────────────────────────
OUTPUT_DIR=outputs
